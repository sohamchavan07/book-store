<div class="bg-white">
  <!-- Hero Section -->
  <div class="relative overflow-hidden pt-16 pb-32">
    <!-- Background decorations -->
    <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3">
      <svg class="w-[800px] h-[800px] text-slate-50 opacity-50" fill="currentColor" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true"><polygon points="0,0 100,0 50,100"/></svg>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center pt-16 pb-12 lg:pt-32">
      <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 tracking-tight mb-6">
        Curate your personal <span class="text-indigo-600">reading list</span>.
      </h1>
      <p class="mt-4 text-xl text-slate-500 max-w-2xl mx-auto mb-10">
        Discover new books, track your reading progress, and build a beautiful digital library that stays with you everywhere.
      </p>
      
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <%= link_to "Explore Books", books_path, class: "inline-flex items-center justify-center px-8 py-3.5 border border-transparent text-base font-medium rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 shadow-sm transition-all hover:-translate-y-0.5" %>
        <%= link_to "Add a Book", new_book_path, class: "inline-flex items-center justify-center px-8 py-3.5 border border-slate-200 text-base font-medium rounded-lg text-slate-700 bg-white hover:bg-slate-50 shadow-sm transition-all hover:-translate-y-0.5" %>
      </div>

      <div class="mt-20 grid grid-cols-2 gap-8 md:grid-cols-3 max-w-3xl mx-auto border-t border-slate-100 pt-10">
        <div>
          <div class="text-3xl font-bold text-slate-900 mb-1">10k+</div>
          <div class="text-sm font-medium text-slate-500 uppercase tracking-wide">Books Tracked</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-slate-900 mb-1">99%</div>
          <div class="text-sm font-medium text-slate-500 uppercase tracking-wide">Satisfaction</div>
        </div>
        <div class="col-span-2 md:col-span-1">
          <div class="text-3xl font-bold text-slate-900 mb-1">24/7</div>
          <div class="text-sm font-medium text-slate-500 uppercase tracking-wide">Availability</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Feature Section -->
  <div class="bg-slate-50 py-24 sm:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <h2 class="text-base font-semibold leading-7 text-indigo-600">Features</h2>
        <p class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Everything you need to track your reading</p>
      </div>
      
      <div class="mx-auto max-w-5xl">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-200/60 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </div>
            <h3 class="text-lg font-semibold text-slate-900 mb-2">Instant Search</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Find any book in your collection instantly with our powerful, intuitive search functionality.</p>
          </div>
          
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-200/60 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            </div>
            <h3 class="text-lg font-semibold text-slate-900 mb-2">Smart Organization</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Categorize your reading list, track status, and organize your digital shelves with ease.</p>
          </div>
          
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-200/60 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path></svg>
            </div>
            <h3 class="text-lg font-semibold text-slate-900 mb-2">Cloud Access</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Your library synchronizes automatically, ensuring your progress is always accessible.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA Section -->
  <div class="bg-indigo-600 py-16 sm:py-24 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center relative z-10">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl text-center">Ready to dive in?</h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-indigo-100 text-center">
          Start building your perfect digital library today. It only takes a minute to get started.
        </p>
        <div class="mt-8 flex justify-center gap-4">
          <%= link_to "Sign up for free", new_user_registration_path, class: "inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-lg text-indigo-600 bg-white hover:bg-indigo-50 shadow-sm transition-colors" %>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="auth-container">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-logo">📚</div>
      <h2 class="auth-title">Welcome Back</h2>
      <p class="auth-subtitle">Sign in to your library account</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <% if flash[:alert] %>
        <div style="color: #ef4444; background: rgba(239, 68, 68, 0.1); padding: 0.75rem; border-radius: 0.5rem; border: 1px solid rgba(239, 68, 68, 0.2); font-size: 0.9rem; text-align: center;">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <% if flash[:notice] %>
        <div style="color: #c084fc; background: rgba(124, 58, 237, 0.1); padding: 0.75rem; border-radius: 0.5rem; border: 1px solid rgba(124, 58, 237, 0.2); font-size: 0.9rem; text-align: center;">
          <%= flash[:notice] %>
        </div>
      <% end %>

      <div class="form-group">
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input", placeholder: "you@example.com" %>
      </div>

      <div class="form-group">
        <%= f.label :password, class: "form-label" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "form-input", placeholder: "••••••••" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-checkbox">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me %>
        </div>
      <% end %>

      <div class="actions">
        <%= f.submit "Sign in", class: "btn-auth" %>
      </div>
    <% end %>

    <div class="auth-footer">
      <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
        <span>Don't have an account? <%= link_to "Sign up", new_registration_path(resource_name), class: "auth-link" %></span>
      <% end %>

      <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
        <%= link_to "Forgot your password?", new_password_path(resource_name), class: "auth-link", style: "font-size: 0.8rem; opacity: 0.8;" %>
      <% end %>
      
      <%= link_to "← Back to Store", root_path, class: "auth-link", style: "font-size: 0.8rem; margin-top: 1rem; opacity: 0.6;" %>
    </div>
  </div>
</div>

<div class="auth-container">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-logo">🔑</div>
      <h2 class="auth-title">Reset Password</h2>
      <p class="auth-subtitle">Enter a new password for your account.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "auth-form" }) do |f| %>
      <%= f.hidden_field :reset_password_token %>

      <% if resource.errors.any? %>
        <div style="color: #ef4444; background: rgba(239, 68, 68, 0.1); padding: 0.75rem; border-radius: 0.5rem; border: 1px solid rgba(239, 68, 68, 0.2); font-size: 0.9rem;">
          <ul style="list-style-type: disc; padding-left: 1.25rem; margin: 0;">
            <% resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-group">
        <%= f.label :password, "New password", class: "form-label" %>
        <% if @minimum_password_length %>
          <span style="font-size: 0.75rem; color: #94a3b8;">(<%= @minimum_password_length %> chars min)</span>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "form-input", placeholder: "••••••••" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm new password", class: "form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input", placeholder: "••••••••" %>
      </div>

      <div class="actions">
        <%= f.submit "Change My Password", class: "btn-auth" %>
      </div>
    <% end %>

    <div class="auth-footer">
      <%= link_to "Sign in", new_session_path(resource_name), class: "auth-link" %>
      <%= link_to "Sign up", new_registration_path(resource_name), class: "auth-link" %>
    </div>
  </div>
</div>

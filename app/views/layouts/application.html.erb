<!DOCTYPE html>
<html class="h-full bg-slate-50 antialiased">
  <head>
    <title>BookStore | Professional Library</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="min-h-full flex flex-col font-sans text-slate-900 bg-white">
    <%= render 'shared/navigation' %>

    <main class="flex-grow">
      <% if notice.present? || alert.present? %>
        <div class="fixed top-24 right-4 z-[100] w-full max-w-sm animate-fade-in-up">
          <% if notice.present? %>
            <div class="bg-white rounded-lg border border-slate-200 shadow-lg p-4 mb-4 flex items-start gap-3">
              <svg class="w-5 h-5 text-emerald-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <div class="flex-1">
                <p class="text-sm font-medium text-slate-900"><%= notice %></p>
              </div>
              <button onclick="this.parentElement.parentElement.remove()" class="text-slate-400 hover:text-slate-500">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              </button>
            </div>
          <% end %>

          <% if alert.present? %>
            <div class="bg-white rounded-lg border border-slate-200 shadow-lg p-4 flex items-start gap-3">
              <svg class="w-5 h-5 text-rose-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
              <div class="flex-1">
                <p class="text-sm font-medium text-slate-900"><%= alert %></p>
              </div>
              <button onclick="this.parentElement.parentElement.remove()" class="text-slate-400 hover:text-slate-500">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              </button>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <%= render 'shared/footer' %>
  </body>
</html>

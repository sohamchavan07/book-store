<footer class="bg-white border-t border-slate-200 mt-auto">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">
      <div class="space-y-6 xl:col-span-1">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-lg bg-indigo-600 flex items-center justify-center text-white shadow-sm">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
          </div>
          <span class="font-bold text-lg text-slate-900">BookStore</span>
        </div>
        <p class="text-sm leading-6 text-slate-500 max-w-xs">
          Your modern digital sanctuary for tracking, finding, and organizing the books you love.
        </p>
        <div class="flex space-x-5">
          <a href="#" class="text-slate-400 hover:text-slate-500">
            <span class="sr-only">X</span>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M13.6823 10.6218L20.2391 3H18.6854L12.9921 9.61788L8.44486 3H3.2002L10.0765 13.0074L3.2002 21H4.75404L10.7663 14.0113L15.5685 21H20.8131L13.6819 10.6218H13.6823ZM11.5541 13.0956L10.8574 12.0991L5.31391 4.16971H7.70053L12.1742 10.5689L12.8709 11.5655L18.6861 19.8835H16.2995L11.5541 13.096V13.0956Z" /></svg>
          </a>
          <a href="#" class="text-slate-400 hover:text-slate-500">
            <span class="sr-only">GitHub</span>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
          </a>
        </div>
      </div>
      <div class="mt-16 grid grid-cols-2 gap-8 xl:col-span-2 xl:mt-0">
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <div>
            <h3 class="text-sm font-semibold leading-6 text-slate-900">Application</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li><%= link_to "Home", root_path, class: "text-sm leading-6 text-slate-600 hover:text-slate-900 transition-colors" %></li>
              <li><%= link_to "Library", books_path, class: "text-sm leading-6 text-slate-600 hover:text-slate-900 transition-colors" %></li>
              <li><%= link_to "Add Book", new_book_path, class: "text-sm leading-6 text-slate-600 hover:text-slate-900 transition-colors" %></li>
            </ul>
          </div>
          <div class="mt-10 md:mt-0">
            <h3 class="text-sm font-semibold leading-6 text-slate-900">Account</h3>
            <ul role="list" class="mt-6 space-y-4">
              <% if user_signed_in? %>
                <li><%= link_to "Profile", "#", class: "text-sm leading-6 text-slate-600 hover:text-slate-900 transition-colors" %></li>
                <li><%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "text-sm leading-6 text-slate-600 hover:text-slate-900 transition-colors" %></li>
              <% else %>
                <li><%= link_to "Log in", new_user_session_path, class: "text-sm leading-6 text-slate-600 hover:text-slate-900 transition-colors" %></li>
                <li><%= link_to "Sign up", new_user_registration_path, class: "text-sm leading-6 text-slate-600 hover:text-slate-900 transition-colors" %></li>
              <% end %>
            </ul>
          </div>
        </div>
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <div>
            <h3 class="text-sm font-semibold leading-6 text-slate-900">Company</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li><a href="#" class="text-sm leading-6 text-slate-600 hover:text-slate-900">About</a></li>
              <li><a href="#" class="text-sm leading-6 text-slate-600 hover:text-slate-900">Blog</a></li>
              <li><a href="#" class="text-sm leading-6 text-slate-600 hover:text-slate-900">Contact</a></li>
            </ul>
          </div>
          <div class="mt-10 md:mt-0">
            <h3 class="text-sm font-semibold leading-6 text-slate-900">Legal</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li><a href="#" class="text-sm leading-6 text-slate-600 hover:text-slate-900">Privacy Policy</a></li>
              <li><a href="#" class="text-sm leading-6 text-slate-600 hover:text-slate-900">Terms of Service</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-16 border-t border-slate-200 pt-8 sm:mt-20 lg:mt-24">
      <p class="text-xs leading-5 text-slate-500">&copy; <%= Time.current.year %> BookStore Inc. All rights reserved.</p>
    </div>
  </div>
</footer>

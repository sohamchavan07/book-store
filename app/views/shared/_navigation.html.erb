    <div class="flex items-center justify-between h-16">
      <div class="flex items-center gap-8">
        <%= link_to root_path, class: "flex items-center gap-2 group" do %>
          <div class="w-8 h-8 rounded-lg bg-indigo-600 flex items-center justify-center text-white shadow-sm group-hover:bg-indigo-700 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
          </div>
          <span class="font-bold text-lg text-slate-900 group-hover:text-indigo-600 transition-colors">BookStore</span>
        <% end %>
        
        <div class="hidden md:flex items-center gap-6">
          <%= link_to "Browse", books_path, class: "text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors" %>

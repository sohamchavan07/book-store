<%= form_with(model: book, class: "space-y-8 animate-fade-in") do |form| %>
  <% if book.errors.any? %>
    <div class="p-6 rounded-2xl bg-rose-50 border border-rose-100 text-rose-800 animate-slide-down">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-2xl">⚠️</span>
        <h3 class="font-black text-lg"><%= pluralize(book.errors.count, "error") %> detected</h3>
      </div>
      <ul class="list-disc list-inside space-y-1 text-sm font-medium opacity-80">
        <% book.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <div class="md:col-span-2 space-y-2">
      <%= form.label :title, class: "text-xs font-black text-slate-400 uppercase tracking-widest ml-1" %>
      <%= form.text_field :title, 
          class: "input-animated block w-full px-6 py-4 bg-white border border-slate-200 rounded-2xl text-slate-900 placeholder-slate-300 font-medium focus:ring-4 focus:ring-violet-500/10", 
          placeholder: "The Great Gatsby" %>
    </div>

    <div class="space-y-2">
      <%= form.label :author, class: "text-xs font-black text-slate-400 uppercase tracking-widest ml-1" %>
      <%= form.text_field :author, 
          class: "input-animated block w-full px-6 py-4 bg-white border border-slate-200 rounded-2xl text-slate-900 placeholder-slate-300 font-medium focus:ring-4 focus:ring-violet-500/10", 
          placeholder: "F. Scott Fitzgerald" %>
    </div>

    <div class="space-y-2">
      <%= form.label :category_id, "Collection", class: "text-xs font-black text-slate-400 uppercase tracking-widest ml-1" %>
      <%= form.collection_select :category_id, Category.all, :id, :name, 
          { prompt: "Select a Category" }, 
          { class: "input-animated block w-full px-6 py-4 bg-white border border-slate-200 rounded-2xl text-slate-900 font-medium focus:ring-4 focus:ring-violet-500/10 appearance-none" } %>
    </div>

    <div class="space-y-2">
      <%= form.label :price, class: "text-xs font-black text-slate-400 uppercase tracking-widest ml-1" %>
      <div class="relative group">
        <div class="absolute inset-y-0 left-0 pl-6 flex items-center pointer-events-none text-slate-400 font-bold">
          ₹
        </div>
        <%= form.number_field :price, step: :any,
            class: "input-animated block w-full pl-10 pr-6 py-4 bg-white border border-slate-200 rounded-2xl text-slate-900 placeholder-slate-300 font-medium focus:ring-4 focus:ring-violet-500/10", 
            placeholder: "0.00" %>
      </div>
    </div>

    <div class="space-y-2">
      <%= form.label :published_on, class: "text-xs font-black text-slate-400 uppercase tracking-widest ml-1" %>
      <%= form.date_field :published_on, 
          class: "input-animated block w-full px-6 py-4 bg-white border border-slate-200 rounded-2xl text-slate-900 font-medium focus:ring-4 focus:ring-violet-500/10" %>
    </div>

    <div class="md:col-span-2 pt-8">
      <%= form.submit class: "btn-hover-lift w-full py-5 bg-slate-900 text-white font-black text-xl rounded-[2rem] shadow-2xl shadow-slate-200 cursor-pointer" %>
    </div>
  </div>
<% end %>

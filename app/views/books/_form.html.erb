
<%= form_with(model: book, class: "auth-form") do |form| %>
  <% if book.errors.any? %>
    <div style="color: #ef4444; background: rgba(239, 68, 68, 0.1); padding: 1rem; border-radius: 0.5rem; border: 1px solid rgba(239, 68, 68, 0.2); margin-bottom: 1.5rem;">
      <h3 style="font-weight: 600; margin-bottom: 0.5rem;"><%= pluralize(book.errors.count, "error") %> prohibited this book from being saved:</h3>
      <ul style="list-style-type: disc; padding-left: 1.5rem;">
        <% book.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-grid">
    <div class="form-group full-width">
      <%= form.label :title, class: "form-label" %>
      <%= form.text_field :title, class: "form-input", placeholder: "e.g. The Great Gatsby" %>
    </div>

    <div class="form-group">
      <%= form.label :author, class: "form-label" %>
      <%= form.text_field :author, class: "form-input", placeholder: "e.g. F. Scott Fitzgerald" %>
    </div>

    <div class="form-group">
      <%= form.label :category_id, "Category", class: "form-label" %>
      <%= form.collection_select :category_id, Category.all, :id, :name, { prompt: "Select a Category" }, { class: "form-input" } %>
    </div>

    <div class="form-group">
      <%= form.label :price, class: "form-label" %>
      <div style="position: relative;">
        <span style="position: absolute; left: 1rem; top: 0.9rem; color: #94a3b8;">₹</span>
        <%= form.text_field :price, class: "form-input", style: "padding-left: 2.5rem;", placeholder: "0.00" %>
      </div>
    </div>

    <div class="form-group">
      <%= form.label :published_on, class: "form-label" %>
      <%= form.date_field :published_on, class: "form-input" %>
    </div>

    <div class="form-actions">
      <%= form.submit class: "btn btn-primary btn-large btn-block" %>
    </div>
  </div>
<% end %>

<style>
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  
  .full-width {
    grid-column: span 2;
  }
  
  .form-actions {
    grid-column: span 2;
    margin-top: 1rem;
  }
  
  @media (max-width: 640px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
    .full-width {
      grid-column: span 1;
    }
  }
</style>

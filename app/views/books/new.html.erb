<div class="max-w-3xl mx-auto py-12 px-4 animate-fade-in">
  <!-- Back Button -->
  <%= link_to books_path, class: "inline-flex items-center gap-2 text-slate-500 hover:text-slate-900 font-bold mb-8 transition-colors group" do %>
    <span class="group-hover:-translate-x-1 transition-transform">←</span>
    <span>Back to Library</span>
  <% end %>

  <div class="card-premium p-10 lg:p-16 bg-white rounded-[3rem] border border-slate-100 shadow-2xl shadow-slate-200/50 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-64 h-64 bg-violet-50 rounded-full -mr-32 -mt-32 blur-3xl opacity-50"></div>
    
    <div class="relative space-y-12">
      <header class="space-y-4">
        <div class="w-16 h-16 bg-slate-900 rounded-2xl flex items-center justify-center text-3xl shadow-xl shadow-slate-200">✨</div>
        <h1 class="text-4xl lg:text-5xl font-black text-slate-900 tracking-tight leading-tight">
          Add New <span class="text-gradient-animated">Treasure</span>
        </h1>
        <p class="text-slate-500 text-lg font-medium leading-relaxed max-w-md">
          Fill in the details below to register a new masterpiece in your personal collection.
        </p>
      </header>

      <%= render "form", book: @book %>
    </div>
  </div>
</div>

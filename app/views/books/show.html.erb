<div class="books-page-container">
  <div class="page-content">
    <div class="book-details-layout">
      <!-- Left Column: Cover Image & Actions -->
      <div class="details-sidebar animate-fade-in">
        <div class="book-cover-large">
          <div class="cover-content">
            <span class="cover-icon-large">📖</span>
          </div>
          <% if @book.category %>
            <div class="category-badge-large">
              <%= @book.category.name %>
            </div>
          <% end %>
        </div>

        <div class="details-actions">
          <%= link_to edit_book_path(@book), class: "btn btn-primary btn-block" do %>
            <span>✏️ Edit Book</span>
          <% end %>
          
          <%= link_to books_path, class: "btn btn-secondary btn-block" do %>
            <span>← Back to Library</span>
          <% end %>
          
          <%= link_to @book, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-danger btn-block" do %>
            <span>🗑 Delete Book</span>
          <% end %>
        </div>
      </div>

      <!-- Right Column: Book Info -->
      <div class="details-content animate-fade-in-delay">
        <h1 class="details-title"><%= @book.title %></h1>
        
        <div class="details-author">
          by <span class="author-name"><%= @book.author %></span>
        </div>

        <div class="details-price-tag">
          ₹<%= number_with_precision(@book.price, precision: 2) %>
        </div>

        <div class="details-card">
          <h3 class="card-section-title">About this Book</h3>
          <div class="info-grid">
            <div class="info-item">
              <span class="info-label">Published</span>
              <span class="info-value"><%= @book.published_on&.strftime("%B %d, %Y") || "Unknown" %></span>
            </div>
            
            <div class="info-item">
              <span class="info-label">Category</span>
              <span class="info-value"><%= @book.category&.name || "Uncategorized" %></span>
            </div>

            <div class="info-item full-width">
              <span class="info-label">Details</span>
              <p class="info-text"><%= @book.formatted_details %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .book-details-layout {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 3rem;
    align-items: start;
    margin-top: 2rem;
  }

  .book-cover-large {
    aspect-ratio: 3/4;
    background: linear-gradient(135deg, #2e1065, #4c1d95);
    border-radius: var(--radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    box-shadow: 0 20px 40px -5px rgba(0,0,0,0.4);
    overflow: hidden;
  }

  .cover-icon-large {
    font-size: 8rem;
    opacity: 0.5;
    filter: drop-shadow(0 10px 10px rgba(0,0,0,0.3));
  }

  .category-badge-large {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    color: #e9d5ff;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .details-actions {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .btn-block {
    display: flex;
    justify-content: center;
    width: 100%;
    padding: 1rem;
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.1);
    color: white;
  }
  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .btn-danger {
    background: rgba(239, 68, 68, 0.1);
    color: #fca5a5;
  }
  .btn-danger:hover {
    background: rgba(239, 68, 68, 0.2);
    color: #f87171;
  }

  .details-content {
    color: white;
  }

  .details-title {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1rem;
    background: linear-gradient(to right, #fff, #e9d5ff);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .details-author {
    font-size: 1.5rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }
  
  .author-name {
    color: var(--primary-color);
    font-weight: 600;
  }

  .details-price-tag {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-accent);
    margin-bottom: 3rem;
    display: inline-block;
    background: rgba(124, 58, 237, 0.1);
    padding: 0.5rem 1.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(124, 58, 237, 0.3);
  }

  .details-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
    padding: 2.5rem;
    backdrop-filter: blur(12px);
  }

  .card-section-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    color: white;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--card-border);
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .full-width {
    grid-column: span 2;
  }

  .info-label {
    font-size: 0.875rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .info-value {
    font-size: 1.1rem;
    color: white;
    font-weight: 500;
  }

  .info-text {
    line-height: 1.7;
    color: #cbd5e1;
  }

  .animate-fade-in-delay {
    animation: fadeIn 0.8s 0.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  @media (max-width: 768px) {
    .book-details-layout {
      grid-template-columns: 1fr;
    }
    
    .book-cover-large {
      max-width: 300px;
      margin: 0 auto;
    }
  }
</style>

<div class="books-page-container">
  <div class="page-content">

    <!-- Header Section -->
    <header class="page-header animate-fade-in">
      <h1 class="main-title">
        All Books
        <span class="subtitle">
          <%= pluralize(@books.count, "book") %> in your collection
        </span>
      </h1>
      
      <!-- Search & Filter Bar -->
      <div class="search-container">
        <%= form_with url: books_path, method: :get, class: "search-form" do %>
          <input type="text" 
                 name="search" 
                 value="<%= params[:search] %>" 
                 placeholder="Search by title, author, or genre..." 
                 class="search-input">
          
          <button type="submit" class="btn btn-search">
            Search
          </button>
        <% end %>
      </div>
    </header>

    <!-- Books Grid -->
    <% if @books.any? %>
      <div class="books-grid">
        <% @books.each do |book| %>
          <article class="book-card group">
            
            <!-- Book Cover Placeholder -->
            <div class="book-cover">
              <div class="cover-content">
                <span class="cover-icon">📖</span>
              </div>
              <% if book.category %>
                <div class="category-badge">
                  <span><%= book.category.name %></span>
                </div>
              <% end %>
            </div>

            <!-- Card Content -->
            <div class="card-body">
              <h3 class="book-title">
                <%= link_to book.title, book %>
              </h3>
              
              <p class="book-author">
                by <span><%= book.author %></span>
              </p>

              <div class="book-meta">
                <div class="book-price">
                  ₹<%= number_with_precision(book.price, precision: 2) %>
                </div>
                <div class="book-date">
                  <%= book.published_on&.strftime("%b %Y") || "Unknown" %>
                </div>
              </div>

              <!-- Action Buttons -->
              <div class="card-actions">
                <%= link_to "View", book, class: "btn btn-view" %>
                <%= link_to "Edit", edit_book_path(book), class: "btn btn-edit" %>
                <%= link_to "Delete", book, 
                    class: "btn btn-delete",
                    data: { turbo_method: :delete, turbo_confirm: "Delete '#{book.title}' permanently?" } %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="empty-state animate-fade-in">
        <div class="empty-icon">📚</div>
        <h3 class="empty-title">No books found</h3>
        <p class="empty-text">
          <% if params[:search].present? %>
            No results for "<strong><%= params[:search] %></strong>"
          <% else %>
            Your library is empty. Start building your collection!
          <% end %>
        </p>
        <%= link_to "Add Your First Book", new_book_path, class: "btn btn-primary btn-large" %>
      </div>
    <% end %>

    <!-- Add New Book CTA -->
    <div class="fab-container">
      <%= link_to new_book_path, class: "btn-fab", title: "Add New Book" do %>
        <span class="fab-icon">+</span>
      <% end %>
    </div>
  </div>
</div>